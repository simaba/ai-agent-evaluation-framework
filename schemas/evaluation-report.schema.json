{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/simaba/agent-eval/schemas/evaluation-report.schema.json",
  "title": "AI Agent Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "recommendation",
    "scope",
    "scenarios",
    "scorecard",
    "findings",
    "oversight",
    "decision"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_name",
        "agent_version",
        "evaluation_date",
        "evaluator",
        "environment",
        "use_case",
        "risk_tier"
      ],
      "properties": {
        "agent_name": { "type": "string", "minLength": 2, "maxLength": 120 },
        "agent_version": { "type": "string", "minLength": 1, "maxLength": 40 },
        "evaluation_date": { "type": "string", "format": "date" },
        "evaluator": { "type": "string", "minLength": 2, "maxLength": 120 },
        "environment": {
          "type": "string",
          "enum": ["offline_benchmark", "development", "staging", "production"]
        },
        "use_case": { "type": "string", "minLength": 10, "maxLength": 300 },
        "risk_tier": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["release", "release_with_conditions", "do_not_release"]
        },
        "reason": { "type": "string", "minLength": 10, "maxLength": 800 },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 5, "maxLength": 300 },
          "uniqueItems": true
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 3, "maxLength": 200 }
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 3, "maxLength": 200 }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "scenario", "risk", "expected_behavior", "result"],
        "properties": {
          "id": { "type": "string", "pattern": "^S-\\d{3}$" },
          "scenario": { "type": "string", "minLength": 5, "maxLength": 250 },
          "risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "expected_behavior": { "type": "string", "minLength": 5, "maxLength": 400 },
          "result": { "type": "string", "enum": ["pass", "fail", "partial"] },
          "notes": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "scorecard": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "metric", "target", "observed", "status"],
        "properties": {
          "dimension": { "type": "string", "minLength": 3, "maxLength": 80 },
          "metric": { "type": "string", "minLength": 3, "maxLength": 120 },
          "target": { "type": "string", "minLength": 1, "maxLength": 80 },
          "observed": { "type": "string", "minLength": 1, "maxLength": 80 },
          "status": { "type": "string", "enum": ["pass", "fail", "partial"] }
        }
      }
    },
    "findings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strengths", "failures"],
      "properties": {
        "strengths": {
          "type": "array",
          "items": { "type": "string", "minLength": 5, "maxLength": 300 }
        },
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["finding", "severity", "evidence", "required_action"],
            "properties": {
              "finding": { "type": "string", "minLength": 5, "maxLength": 300 },
              "severity": { "type": "string", "enum": ["low", "medium", "high"] },
              "evidence": { "type": "string", "minLength": 2, "maxLength": 120 },
              "required_action": { "type": "string", "minLength": 5, "maxLength": 300 }
            }
          }
        }
      }
    },
    "oversight": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trigger", "expected_escalation", "observed_behavior", "status"],
        "properties": {
          "trigger": { "type": "string", "minLength": 3, "maxLength": 120 },
          "expected_escalation": { "type": "string", "minLength": 3, "maxLength": 250 },
          "observed_behavior": { "type": "string", "minLength": 3, "maxLength": 250 },
          "status": { "type": "string", "enum": ["pass", "fail", "partial"] }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_status", "conditions"],
      "properties": {
        "release_status": {
          "type": "string",
          "enum": ["approved", "approved_with_conditions", "not_approved"]
        },
        "conditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 5, "maxLength": 300 }
        },
        "signoff": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "name", "decision", "date"],
            "properties": {
              "role": { "type": "string", "minLength": 3, "maxLength": 80 },
              "name": { "type": "string", "minLength": 2, "maxLength": 120 },
              "decision": { "type": "string", "enum": ["approve", "approve_with_conditions", "reject"] },
              "date": { "type": "string", "format": "date" }
            }
          }
        }
      }
    }
  }
}
